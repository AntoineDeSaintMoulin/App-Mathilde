import { useEffect, useState } from 'react';
import { supabase } from './supabaseClient';

const USER_ID = 'mathilde';
const SESSION_ID = Math.random().toString(36).substr(2, 9);

export const usePresence = () => {
  const [conflict, setConflict] = useState(false);
  const [sessionCount, setSessionCount] = useState(1);

  useEffect(() => {
    const register = async () => {
      await supabase.from('presence').upsert({
        session_id: SESSION_ID,
        user_id: USER_ID,
        last_seen: new Date().toISOString()
      });
    };

    const check = async () => {
      // Nettoie toutes les sessions inactives depuis plus de 2 minutes
      await supabase
        .from('presence')
        .delete()
        .eq('user_id', USER_ID)
        .lt('last_seen', new Date(Date.now() - 2 * 60 * 1000).toISOString());

      // Récupère toutes les sessions actives restantes
      const { data } = await supabase
        .from('presence')
        .select('session_id')
        .eq('user_id', USER_ID);

      if (data) {
        setSessionCount(data.length);
        setConflict(data.length > 1);
      }
    };

    register();
    check();

    const heartbeat = setInterval(() => {
      register();
      check();
    }, 30000);

    const cleanup = () => {
      supabase.from('presence').delete().eq('session_id', SESSION_ID);
    };

    window.addEventListener('beforeunload', cleanup);

    return () => {
      clearInterval(heartbeat);
      window.removeEventListener('beforeunload', cleanup);
    };
  }, []);

  return { conflict, sessionCount };
};
